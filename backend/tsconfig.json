{
 
  "compilerOptions": {

    "module": "nodenext",
    "target": "es2022",
    "moduleResolution": "nodenext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": false 
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
